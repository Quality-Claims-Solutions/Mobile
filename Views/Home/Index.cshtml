@using Mobile.Models.ViewModels
@using Mobile.Utilities
@{
    ViewData["Title"] = "Home Page";
}

@foreach(CardLossMenuViewModel menuItem in Model.MenuItems)
{
    <div class="card rental-card" id="@menuItem.HTMLId">

        <div class="card-body d-flex align-items-center">
            <div class="card-icon">
                <i class="@menuItem.Icon"></i>
            </div>

            <div class="card-text">
                <p>@Html.Raw(@menuItem.Description)</p>
            </div>
        </div>

        <div class="card-footer">
            <a href="@menuItem.Target" class="btn card-button">
                Rental Photos
            </a>
        </div>
    </div>
}
