@using Mobile.Models.Other
@using Mobile.Utilities
@*Sets the CSS and Logo for branding (set from Program.cs)*@
@{
    var brand = Context.Items["Brand"] as BrandInfo;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mobile</title>

    <!-- Bootstrap / Bootswatch -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css">

    <!-- FlatPickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <!-- Brand Theme -->
    <link rel="stylesheet" href="@brand.CssPath" />

    <!-- App Styles -->
    <link rel="stylesheet" href="~/css/camera.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Mobile.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=ink_eraser" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>
<body>
    <header class="d-flex align-items-center">
        <div class="d-flex justify-content-between align-items-center w-100" style="padding-left: 10px; padding-right: 10px;">
            <div style="font-size:large; font-weight:bold">
                @(User.GetUserDisplayName() ?? "Welcome!")
            </div>

            <div class="d-flex align-items-center">
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-primary me-2 d-inline-flex align-items-center" style="color: white"
                       asp-controller="Home"
                       asp-action="Index">
                        Dash
                    </a>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        <button type="submit" class="btn btn-primary">Log Out</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-primary me-2 d-inline-flex align-items-center" style="color: white" 
                        asp-controller="Account" 
                        asp-action="Login">
                            Log In
                    </a>
                }
            </div>
        </div>
    </header>
    <div style="text-align:center; padding-bottom: 20px;">
        <img src="@brand.LogoPath" alt="Brand Logo" />
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Mobile - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    
    @* FlatPickr *@
    <script defer src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    @* Added by Colton *@
    <script src="https://cdn.jsdelivr.net/npm/localforage@1.10.0/dist/localforage.min.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>


    <!-- COLTON ADDED FOR NEW CAMERA-->
    <script type="module" src="~/js/Camera/camera.js"></script>

    @* Materialize *@
    @* <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize Materialize components globally
            M.AutoInit();
        });
    </script> *@

    @*Bootstrap*@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @* This is where Toast notifications reside *@
    <div id="toastContainer"
         data-toast-type="@TempData["Toast.Type"]"
         data-toast-message="@TempData["Toast.Message"]">
    </div>
</body>
</html>
