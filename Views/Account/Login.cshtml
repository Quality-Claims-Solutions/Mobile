@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

@section Scripts {
    <script src="~/js/Account/Login.js"></script>
}

<form asp-action="Login" id="loginForm" method="post" class="p-4 shadow rounded bg-white" style="max-width: 400px; margin: auto;">
    <div class="mb-3">
        <span class="form-label d-block fw-semibold">Login with</span>
        <div class="form-check form-check-inline">
            <input class="form-check-input"
                   type="radio"
                   asp-for="UseEmail"
                   value="true"
                   id="useEmailRadio"
                   checked
                   aria-controls="emailGroup">
            <label class="form-check-label" for="useEmailRadio">Email</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input"
                   type="radio"
                   asp-for="UseEmail"
                   value="false"
                   id="useEmployeeRadio"
                   aria-controls="employeeGroup">
            <label class="form-check-label" for="useEmployeeRadio">Employee ID</label>
        </div>
    </div>

    <!-- Email (floating, underline-only) -->
    <div class="form-floating mb-3" id="emailGroup">
        <input asp-for="Email"
               class="form-control"
               type="email"
               placeholder=" "
               autocomplete="email" />
        <label asp-for="Email"></label>
        <div class="invalid-feedback">Please enter a valid email address.</div>
        <span class="text-danger" asp-validation-for="Email"></span>
    </div>

    <!-- Employee ID (floating, underline-only; initially hidden) -->
    <div class="form-floating mb-3 d-none" id="employeeGroup">
        <input asp-for="EmployeeId"
               class="form-control"
               inputmode="numeric"
               pattern="[0-9]*"
               placeholder=" "
               autocomplete="username" />
        <label asp-for="EmployeeId">Employee Id</label>
        <div class="invalid-feedback">Please enter your employee ID.</div>
        <span class="text-danger" asp-validation-for="EmployeeId"></span>
    </div>

    <!-- Password -->
    <div class="form-floating mb-3">
        <input asp-for="Password"
               type="password"
               class="form-control"
               placeholder=" "
               autocomplete="current-password"
               required />
        <label asp-for="Password"></label>
        <div class="invalid-feedback">Password is required.</div>
        <span class="text-danger" asp-validation-for="Password"></span>
    </div>

    <!-- Remember Me (kept standard for clarity) -->
    <div class="form-check mb-3">
        <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
        <label class="form-check-label" for="rememberMe">Remember me</label>
    </div>

    <!-- Validation summary + error banner (unchanged) -->
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
    @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
    {
        <div class="alert alert-danger py-2" role="alert">@Model.ErrorMessage</div>
    }

    <button type="submit" class="btn btn-primary w-100">Log In</button>
</form>
